{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fips.network/schemas/render-frame-v1alpha1.schema.json",
  "title": "FIPS Wind Tunnel Render Frame v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "frame_index",
    "virtual_time_ns",
    "presentation",
    "fidelity",
    "primitives",
    "reconciliation",
    "delta",
    "violations"
  ],
  "properties": {
    "schema": {
      "const": "experiments.fips.network/render-frame/v1alpha1"
    },
    "frame_index": { "type": "integer", "minimum": 0 },
    "virtual_time_ns": { "type": "integer", "minimum": 0 },
    "presentation": { "$ref": "#/$defs/presentation" },
    "fidelity": { "$ref": "#/$defs/fidelity" },
    "primitives": { "$ref": "#/$defs/primitives" },
    "reconciliation": { "$ref": "#/$defs/reconciliation" },
    "delta": { "$ref": "#/$defs/delta" },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "from_ns",
        "through_ns",
        "event_ids",
        "event_kinds",
        "event_times_ns",
        "event_ordinals",
        "causal_parents",
        "initiating_event_ids"
      ],
      "properties": {
        "mode": {
          "enum": [
            "idle",
            "interpolation",
            "ordered-event",
            "exact-event-summary",
            "seek-replay"
          ]
        },
        "from_ns": { "type": "integer", "minimum": 0 },
        "through_ns": { "type": "integer", "minimum": 0 },
        "event_ids": { "$ref": "#/$defs/stringArray" },
        "event_kinds": { "$ref": "#/$defs/stringArray" },
        "event_times_ns": { "$ref": "#/$defs/nonnegativeIntegerArray" },
        "event_ordinals": { "$ref": "#/$defs/nonnegativeIntegerArray" },
        "causal_parents": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        },
        "initiating_event_ids": { "$ref": "#/$defs/stringArray" },
        "compression_reason": {
          "enum": [
            "same-timestamp-burst",
            "playback-window-density",
            "explicit-seek"
          ]
        }
      }
    },
    "fidelity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_fidelity", "visible_state", "temporal", "layout", "cohorts"],
      "properties": {
        "source_fidelity": { "type": "string" },
        "visible_state": { "type": "string" },
        "temporal": { "type": "string" },
        "layout": { "type": "string" },
        "cohorts": { "type": "string" }
      }
    },
    "primitives": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "physical_links",
        "parent_relations",
        "routes",
        "transmissions",
        "cohorts",
        "cohort_transmissions"
      ],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "physical_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        },
        "parent_relations": {
          "type": "array",
          "items": { "$ref": "#/$defs/parent" }
        },
        "routes": {
          "type": "array",
          "items": { "$ref": "#/$defs/route" }
        },
        "transmissions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transmission" }
        },
        "cohorts": {
          "type": "array",
          "items": { "$ref": "#/$defs/cohort" }
        },
        "cohort_transmissions": {
          "type": "array",
          "items": { "$ref": "#/$defs/cohortTransmission" }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "active",
        "root",
        "sequence",
        "transport",
        "world_x",
        "world_y",
        "source"
      ],
      "properties": {
        "id": { "type": "integer" },
        "active": { "type": "boolean" },
        "root": { "type": "integer" },
        "parent": { "type": ["integer", "null"] },
        "sequence": { "type": "integer" },
        "transport": { "type": "string" },
        "world_x": { "type": "number" },
        "world_y": { "type": "number" },
        "source": { "type": "string" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "active", "source"],
      "properties": {
        "id": { "type": "integer" },
        "from": { "type": "integer" },
        "to": { "type": "integer" },
        "active": { "type": "boolean" },
        "source": { "type": "string" }
      }
    },
    "parent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["child", "parent", "source"],
      "properties": {
        "child": { "type": "integer" },
        "parent": { "type": "integer" },
        "source": { "type": "string" }
      }
    },
    "transmission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "start_ns",
        "end_ns",
        "plane",
        "progress",
        "source"
      ],
      "properties": {
        "id": { "type": "string" },
        "from": { "type": "integer" },
        "to": { "type": "integer" },
        "start_ns": { "type": "integer", "minimum": 0 },
        "end_ns": { "type": "integer", "minimum": 0 },
        "plane": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transfer_id", "node_ids", "source"],
      "properties": {
        "transfer_id": { "type": "string" },
        "node_ids": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "source": { "type": "string" }
      }
    },
    "cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "depth_band",
        "transport",
        "node_ids",
        "active_nodes",
        "world_x",
        "world_y",
        "source"
      ],
      "properties": {
        "root": { "type": "integer" },
        "depth_band": { "type": "integer", "minimum": 0 },
        "transport": { "type": "string" },
        "node_ids": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "active_nodes": { "type": "integer", "minimum": 0 },
        "world_x": { "type": "number" },
        "world_y": { "type": "number" },
        "source": { "type": "string" }
      }
    },
    "cohortTransmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "plane", "count", "mean_progress", "source"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "plane": { "type": "string" },
        "count": { "type": "integer", "minimum": 1 },
        "mean_progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string" }
      }
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_nodes",
        "visible_nodes",
        "source_physical_links",
        "visible_physical_links",
        "source_parent_relations",
        "visible_parent_relations",
        "source_routes",
        "visible_routes",
        "source_transmissions",
        "visible_transmissions",
        "intentionally_omitted",
        "violations"
      ],
      "properties": {
        "source_nodes": { "type": "integer", "minimum": 0 },
        "visible_nodes": { "type": "integer", "minimum": 0 },
        "source_physical_links": { "type": "integer", "minimum": 0 },
        "visible_physical_links": { "type": "integer", "minimum": 0 },
        "source_parent_relations": { "type": "integer", "minimum": 0 },
        "visible_parent_relations": { "type": "integer", "minimum": 0 },
        "source_routes": { "type": "integer", "minimum": 0 },
        "visible_routes": { "type": "integer", "minimum": 0 },
        "source_transmissions": { "type": "integer", "minimum": 0 },
        "visible_transmissions": { "type": "integer", "minimum": 0 },
        "intentionally_omitted": { "type": "integer", "minimum": 0 },
        "violations": { "$ref": "#/$defs/stringArray" }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "added_node_ids",
        "removed_node_ids",
        "changed_node_ids",
        "changed_physical_link_ids",
        "changed_parent_node_ids",
        "changed_route_ids",
        "started_transmission_ids",
        "ended_transmission_ids",
        "advanced_transmission_ids",
        "changed_cohorts",
        "layout_only_node_ids"
      ],
      "properties": {
        "added_node_ids": { "$ref": "#/$defs/integerArray" },
        "removed_node_ids": { "$ref": "#/$defs/integerArray" },
        "changed_node_ids": { "$ref": "#/$defs/integerArray" },
        "changed_physical_link_ids": { "$ref": "#/$defs/integerArray" },
        "changed_parent_node_ids": { "$ref": "#/$defs/integerArray" },
        "changed_route_ids": { "$ref": "#/$defs/stringArray" },
        "started_transmission_ids": { "$ref": "#/$defs/stringArray" },
        "ended_transmission_ids": { "$ref": "#/$defs/stringArray" },
        "advanced_transmission_ids": { "$ref": "#/$defs/stringArray" },
        "changed_cohorts": { "$ref": "#/$defs/stringArray" },
        "layout_only_node_ids": { "$ref": "#/$defs/integerArray" }
      }
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "integerArray": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "nonnegativeIntegerArray": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    }
  }
}
