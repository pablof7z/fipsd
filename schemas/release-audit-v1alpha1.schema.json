{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://experiments.fips.network/schemas/release-audit-v1alpha1.schema.json",
  "title": "FIPS Wind Tunnel Release Audit v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "release", "determinism", "accounting", "support_matrix", "threat_controls", "limitations", "ready"],
  "properties": {
    "api_version": {"const": "experiments.fips.network/release-audit/v1alpha1"},
    "release": {"const": "0.1.0"},
    "determinism": {"type": "object", "required": ["repetitions", "dimensions", "passed"]},
    "accounting": {"type": "object", "required": ["projections", "exclusions", "unobserved", "passed"]},
    "support_matrix": {"type": "array", "minItems": 1},
    "threat_controls": {"type": "array", "minItems": 1},
    "limitations": {"type": "array", "minItems": 1},
    "ready": {"const": true}
  }
}
