{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fips.network/schemas/normalized-plan-v1alpha1.schema.json",
  "title": "FIPS Wind Tunnel normalized plan v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "campaign_sha256", "campaign", "axes", "seed"],
  "properties": {
    "api_version": { "const": "experiments.fips.network/normalized-plan/v1alpha1" },
    "campaign_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "campaign": { "type": "object" },
    "axes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "values"],
        "properties": {
          "path": { "type": "string", "pattern": "^/" },
          "values": { "type": "array", "minItems": 1 }
        }
      }
    },
    "seed": { "type": "integer", "minimum": 0 }
  }
}
